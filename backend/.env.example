# --- SUPABASE SETTINGS ---
# Go to Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI / RAG SETTINGS ---
# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# --- LIVE TRAFFIC DATA ---
# TomTom Developer Portal: https://developer.tomtom.com/
TOMTOM_API_KEY="your-tomtom-api-key"

# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY="your-openweathermap-api-key"

# --- OPTIONAL: CAMERA STREAMS ---
# RTSP URL for the primary camera (Silk Board)
# CCTV_RTSP_URL="rtsp://your-camera-stream-url"

# --- OPTIONAL: FRONTEND ORIGINS ---
# Comma-separated list of allowed frontend origins (default: localhost:8080,localhost:3000,localhost:5173)
# FRONTEND_ORIGINS="http://localhost:8080,http://localhost:3000"
