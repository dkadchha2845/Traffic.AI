{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nexus-grid-logic-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://nexus-grid-logic-backend.onrender.com/ws/:path*"
    }
  ],
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}
